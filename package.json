{
  "name": "kanbento",
  "version": "0.2.1",
  "type": "module",
  "description": "A file-based kanban board for coordinating work across agent sessions and repos.",
  "license": "FSL-1.1-Apache-2.0",
  "homepage": "https://kanbento.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quantify/kanbento.git"
  },
  "bugs": {
    "url": "https://github.com/quantify/kanbento/issues"
  },
  "keywords": [
    "kanban",
    "agents",
    "agentic",
    "event-sourcing",
    "cli",
    "project-management",
    "knowledge-management"
  ],
  "bin": {
    "kanbento": "src/cli.js"
  },
  "files": [
    "src",
    "procedures",
    "!procedures/*/test",
    "examples/*/manifest.*",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "k": "node src/cli.js",
    "test": "mocha \"test/*.test.js\" \"procedures/*/test/*.test.js\"",
    "prepublishOnly": "npm audit --audit-level=low"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "mocha": "^11.7.6"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5",
    "diff": "^8.0.3"
  }
}
